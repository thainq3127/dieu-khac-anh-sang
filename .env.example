# ============================================================
# Komodo Stack runtime variables
# ============================================================

# Image is produced and pushed by the separate Komodo Build resource.
# Use :latest for the normal lane, or pin an immutable commit-SHA tag for rollback.
APP_IMAGE=registry.vrtour.vn/admin/dieu-khac-anh-sang:latest
APP_HOST_PORT=31414
DB_HOST_PORT=23435

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=dieu_khac_anh_sang
DATABASE_URL=postgresql://postgres:replace-with-a-url-encoded-password@db:5432/dieu_khac_anh_sang

# Optional staging/site-view gate. Leave both empty to disable.
# This is separate from CMS admin login.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# CMS authoring login. Used for /admin and admin mutations.
AUTH_URL=https://dkas.khonggianvanhoa.vn
AUTH_SECRET=replace-with-at-least-32-random-bytes
AUTH_TRUST_HOST=true
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-long-random-password

# Stable Next.js Server Actions encryption key.
# This same value must also be configured as a Build resource build argument.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=replace-with-a-base64-encoded-32-byte-key

# S3-compatible storage. These values are server-only.
S3_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1
S3_BUCKET=dkas-media
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me

# Optional runtime analytics / AI integrations.
GA_PROPERTY_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GEMINI_API_KEY=

# ============================================================
# Komodo Build resource arguments
# ============================================================
# These are consumed while building the Next.js image and do not belong in
# compose.yaml. Configure them on the dedicated Build resource.

NEXT_PUBLIC_ASSET_BASE_URL=https://assets.example.com/dkas-media
NEXT_PUBLIC_GA_ID=
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY uses the same value as the runtime variable above.
