# Database
DATABASE_URL=

# Optional staging/site-view gate. Disable/remove when the public website goes live.
# This is separate from CMS admin login.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# CMS authoring login. Used for /admin and admin mutations.
# AUTH_URL must be set to the full public URL in production (e.g. https://yourdomain.com).
# Without it, NextAuth cannot construct correct redirect URLs after login.
AUTH_URL=
AUTH_SECRET=
AUTH_TRUST_HOST=true
ADMIN_EMAIL=
ADMIN_PASSWORD=

# MinIO / S3-compatible upload API.
# DB stores only object paths, for example: uploads/a.jpg or migrated/b.jpg.
# S3_* values are server-only and are used only for uploading objects to MinIO.
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Public asset base URL used by browser/client rendering to expand stored paths.
# Example: NEXT_PUBLIC_ASSET_BASE_URL=https://asset.vanhoacham.vrtour.vn/media
# uploads/a.jpg -> https://asset.vanhoacham.vrtour.vn/media/uploads/a.jpg
# If your proxy maps bucket `media` directly to the domain root, use:
# NEXT_PUBLIC_ASSET_BASE_URL=https://asset.vanhoacham.vrtour.vn
NEXT_PUBLIC_ASSET_BASE_URL=

# Analytics / AI integrations
NEXT_PUBLIC_GA_ID=G-NMW3KT2356
GA_PROPERTY_ID=392170311
